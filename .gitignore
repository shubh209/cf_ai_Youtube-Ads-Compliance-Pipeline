# ============================================================
#  Brand Guardian AI — .gitignore
# ============================================================

# --- Environment & Secrets (NEVER commit these) -------------
.env
.env.*
!.env.example

# --- Python ---------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/

# --- Temporary video files (created during pipeline runs) ----
*.mp4
*.avi
*.mov
*.mkv
temp_audit_video.mp4

# --- uv -------------------------------------------------------
# Keep uv.lock committed — it ensures reproducible installs
# Keep pyproject.toml committed
# Only ignore the cache
.uv/

# --- IDE & OS -------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Logs -----------------------------------------------------
*.log
logs/

# --- Docker ---------------------------------------------------
.dockerignore

# --- Pytest / Testing -----------------------------------------
.pytest_cache/
.coverage
htmlcov/cookies.txt
cookies.txt

skills-main/
.commitshow/
