# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/brand_guardian

# ── Microsoft Entra ID ──────────────────────────────────────────────────────
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_AUTHORITY=
ENTRA_API_AUDIENCE=
ENTRA_ADMIN_ROLE=Admin
ENTRA_REVIEWER_ROLE=Reviewer
ENTRA_READ_ONLY_ROLE=ReadOnly
ENTRA_DEFAULT_ROLE=reviewer

# Local development only. Never enable in production.
AUTH_DISABLED=false
DEV_ENTRA_OID=local-dev-user
DEV_USER_EMAIL=dev@localhost
DEFAULT_TEAM_NAME=Default Team

# ── Security ────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8000
RATE_LIMIT_PER_MINUTE=30

# ── RAG ─────────────────────────────────────────────────────────────────────
RAG_TOP_K=8

AZURE_STORAGE_CONNECTION_STRING=""

AZURE_OPENAI_API_KEY=<YOUR_AZURE_OPENAI_API_KEY>
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_VERSION="2024-02-01"
AZURE_OPENAI_CHAT_DEPLOYMENT="gpt-4o"
AZURE_OPENAI_EMBEDDING_DEPLOYMENT="text-embedding-3-small"

AZURE_SEARCH_ENDPOINT=""
AZURE_SEARCH_API_KEY=<YOUR_SEARCH_ADMIN_KEY>
AZURE_SEARCH_INDEX_NAME=""

AZURE_VI_NAME=""
AZURE_VI_ACCOUNT_ID=<YOUR_VIDEO_INDEXER_ACCOUNT_ID>
AZURE_VI_LOCATION="eastus"
AZURE_SUBSCRIPTION_ID=<YOUR_AZURE_SUBSCRIPTION_ID>
AZURE_RESOURCE_GROUP=""

APPLICATIONINSIGHTS_CONNECTION_STRING=

LOG_LEVEL=INFO

LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=""
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT=""
